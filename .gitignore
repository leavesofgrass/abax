# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.tox/
.nox/
.hypothesis/
# Jupyter (abax ships a kernel; notebooks can drop checkpoints beside the tree)
.ipynb_checkpoints/

# Coverage.py data + reports (see [tool.coverage] in pyproject / CI coverage job)
.coverage
.coverage.*
htmlcov/
coverage.xml

# Build artifacts
build/
dist/
# macOS icon build artifacts (generated in CI from packaging/appimage/abax.svg)
packaging/macos/abax.iconset/
packaging/macos/abax.icns
packaging/macos/*.svg.png
# pyz build-staging dir (see make_pyz.py / just pyz)
_stage/
*.egg-info/
*.egg

# Packaging / installer output
*.whl
*.tar.gz
*.pyz

# Virtual environments
.venv/
venv/
env/
ENV/

# Editors / IDEs
.vscode/
.idea/
*.swp
*~
# Merge / patch leftovers
*.orig
*.rej
*.bak

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Secrets / local environment — never commit credentials or API keys.
# (Connection secrets are kept out of the workbook at runtime; this is a
# belt-and-suspenders guard against a stray dotenv landing in the tree.)
.env
.env.*
!.env.example
.envrc

# abax runtime data that may appear if run from the source tree
# (config/cache/logs normally live in the platform dirs, not here)
*.log

# AI assistant / agent files — not part of the project
CLAUDE.md
GEMINI.md
AGENTS.md
.claude/
.github/copilot-instructions.md

# Personal / working notes — not part of the release
dev/
docs/roadmaps/

# Output files written by the runnable examples (docs/examples/*/*/run.py)
docs/examples/*/*/out/

# MkDocs build output
site/
